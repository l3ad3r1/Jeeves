<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Already declared by the host :app: INTERNET, ACCESS_COARSE_LOCATION,
         RECEIVE_BOOT_COMPLETED, WAKE_LOCK, FOREGROUND_SERVICE, POST_NOTIFICATIONS. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD" />

    <application>
        <!--
          Differences from the standalone manifest:
            - no <application> attributes (icon/label/theme/backup): the host owns them.
              Each activity therefore names its own theme explicitly.
            - MainAlarmSetupActivity loses its MAIN/LAUNCHER intent-filter (the host keeps
              the sole launcher entry) and is started from the host's hub, so it no longer
              needs to be exported.
            - AlarmReceiver keeps its own BOOT_COMPLETED filter. The host's BootReceiver
              also listens for BOOT_COMPLETED; both coexist, they are distinct classes and
              both must run on boot (Butler re-registers alarms, Hermes restarts its agent).
            - AlarmForegroundService keeps foregroundServiceType="mediaPlayback", distinct
              from the host's dataSync services. The app declares both permissions.
        -->
        <activity
            android:name=".MainAlarmSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"
            android:launchMode="singleTop" />

        <activity
            android:name=".AlarmActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"
            android:launchMode="singleInstance"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:taskAffinity=".alarm"
            android:excludeFromRecents="true" />

        <receiver
            android:name=".AlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.sassybutler.alarm.ACTION_ALARM_FIRE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".AlarmForegroundService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />
    </application>

</manifest>
