<?xml version="1.0" encoding="utf-8"?>
<!-- Selector chip (honorific / snooze / day): ink when selected, cream otherwise -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/ink" />
            <stroke android:width="1.5dp" android:color="@color/ink" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/cream" />
            <stroke android:width="1.5dp" android:color="@color/linen_border" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
