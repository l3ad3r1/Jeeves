<?xml version="1.0" encoding="utf-8"?>
<!-- Sass slider track: green→blue gradient up to the thumb, parchment after
     (design: linear-gradient(to right, apple_green 0%, powder_blue pct%, parchment pct%)) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="@color/parchment" />
            <corners android:radius="3dp" />
            <size android:height="6dp" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <gradient
                    android:angle="0"
                    android:startColor="@color/apple_green"
                    android:endColor="@color/powder_blue" />
                <corners android:radius="3dp" />
                <size android:height="6dp" />
            </shape>
        </clip>
    </item>
</layer-list>
