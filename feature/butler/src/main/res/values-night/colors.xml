<?xml version="1.0" encoding="utf-8"?>
<!--
  Alarms — dark palette.

  Mirrors the dark half of the one Jeeves palette in :core:theme
  (com.jeeves.core.theme.JeevesPalette). Butler is View-based and cannot consume a Compose
  ColorScheme, so the hex values are duplicated here by necessity: change one, change the other.

  The semantic names are kept (cream = background, ink = text) so no layout or style had to be
  touched — only their values flip under -night. Fixes docs/UX_AUDIT.md JX-06, where the alarm
  app stayed light at 6 AM.
-->
<resources>
    <color name="cream">#000000</color>          <!-- background  = JeevesPalette.DarkBackground -->
    <color name="card">#111111</color>           <!-- card surface = DarkSurface -->
    <color name="ink">#FFFFFF</color>            <!-- primary text = DarkOnBackground -->
    <color name="parchment">#1C1C1C</color>      <!-- muted surface = DarkSurfaceVariant -->
    <color name="linen_border">#333333</color>   <!-- borders = DarkOutline -->
    <color name="warm_grey">#999999</color>      <!-- muted text = DarkOnSurfaceVariant (7.4:1 on black) -->
    <color name="faded_grey">#8A8A8A</color>     <!-- disabled text (6.1:1; the light value fails WCAG) -->
    <color name="powder_blue">#87BDD4</color>    <!-- accent: 10.3:1 on black, already safe -->
    <color name="apple_green">#46D399</color>    <!-- JeevesPalette good (11.0:1) -->
    <color name="butler_red">#FF4444</color>     <!-- DarkError (6.2:1) -->

    <!-- The wake screen was always dark; unchanged. -->
    <color name="wake_top">#1C2127</color>
    <color name="wake_mid">#1E3A4A</color>
    <color name="wake_bottom">#0F2030</color>
    <color name="wake_text">#F5F2EE</color>
</resources>
