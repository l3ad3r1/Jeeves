<?xml version="1.0" encoding="utf-8"?>
<!-- Wake-up screen (design: WakeUpScreen.tsx) -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_wake_gradient">

    <!-- Faint bowler hat, top-right, rotated -->
    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="-40dp"
        android:rotation="12"
        android:alpha="0.04"
        android:src="@drawable/ic_bowler_hat"
        app:tint="@android:color/white"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- "Alarm Active" strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="14dp">

            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alarm Active"
                android:textSize="12sp"
                android:textStyle="italic"
                android:fontFamily="@font/dm_sans"
                android:textColor="#80F5F2EE" />
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="WEDNESDAY, 9 JULY"
            android:textSize="12sp"
            android:letterSpacing="0.18"
            android:fontFamily="@font/cinzel"
            android:textColor="#B387BDD4" />

        <!-- Clock -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="07:07"
            android:textSize="80sp"
            android:fontFamily="@font/cinzel"
            android:letterSpacing="0.01"
            android:includeFontPadding="false"
            android:textColor="@color/wake_text" />

        <TextView
            android:id="@+id/tvSeconds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00"
            android:textSize="22sp"
            android:letterSpacing="0.18"
            android:fontFamily="@font/cinzel"
            android:textColor="#8087BDD4" />

        <!-- Butler speaking card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="36dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_speech_card">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:id="@+id/ivSoundBars"
                    android:layout_width="18dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_sound_bars"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="BUTLER SPEAKING"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="@font/cinzel"
                    android:textColor="#9987BDD4" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="44dp"
                android:text=""
                android:textSize="15sp"
                android:textStyle="italic"
                android:fontFamily="@font/playfair_display"
                android:textColor="@color/wake_text"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Butler tuxedo motif -->
        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="24dp"
            android:alpha="0.55"
            android:src="@drawable/ic_tuxedo"
            app:tint="@color/powder_blue"
            android:contentDescription="@null" />

        <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Hush button + pulse rings -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/pulseRing1"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/ring_hush_pulse" />

            <View
                android:id="@+id/pulseRing2"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/ring_hush_pulse" />

            <LinearLayout
                android:id="@+id/btnHush"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_hush_circle"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hush"
                    android:textSize="22sp"
                    android:textStyle="italic"
                    android:fontFamily="@font/playfair_display"
                    android:textColor="@color/wake_text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="DISMISS"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="@font/cinzel"
                    android:textColor="#B387BDD4" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/btnSnooze"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:padding="12dp"
            android:text="Snooze (10 min)"
            android:textSize="13sp"
            android:fontFamily="@font/dm_sans"
            android:textColor="#8087BDD4"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>
</FrameLayout>
