<?xml version="1.0" encoding="utf-8"?>
<!-- "A New Appointment" / edit sheet (design: ParlourScreen modal) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="48dp">

    <TextView
        android:id="@+id/tvSheetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A New Appointment"
        android:textSize="22sp"
        android:textStyle="italic"
        android:fontFamily="@font/playfair_display"
        android:textColor="@color/ink" />

    <TextView
        android:id="@+id/tvSheetSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="20dp"
        android:text="I shall prepare accordingly."
        android:textSize="12sp"
        android:fontFamily="@font/dm_sans"
        android:textColor="@color/faded_grey" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="TIME"
        android:textSize="11sp"
        android:letterSpacing="0.14"
        android:fontFamily="@font/cinzel"
        android:textColor="@color/warm_grey" />

    <LinearLayout
        android:id="@+id/timeField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/bg_input"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvTimeValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="08:00 AM"
            android:textSize="26sp"
            android:fontFamily="@font/cinzel"
            android:letterSpacing="0.01"
            android:textColor="@color/ink" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_clock"
            app:tint="@color/ink"
            android:contentDescription="@null" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="LABEL"
        android:textSize="11sp"
        android:letterSpacing="0.14"
        android:fontFamily="@font/cinzel"
        android:textColor="@color/warm_grey" />

    <EditText
        android:id="@+id/etLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Morning Obligations…"
        android:textColorHint="@color/faded_grey"
        android:textColor="@color/ink"
        android:textSize="15sp"
        android:fontFamily="@font/dm_sans"
        android:inputType="textCapSentences"
        android:maxLines="1"
        android:padding="14dp"
        android:background="@drawable/bg_input"
        android:layout_marginBottom="16dp"
        android:importantForAutofill="no" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="REPEATS"
        android:textSize="11sp"
        android:letterSpacing="0.14"
        android:fontFamily="@font/cinzel"
        android:textColor="@color/warm_grey" />

    <LinearLayout
        android:id="@+id/dayChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/btnCreate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="Set the Alarm, Butler"
        android:textSize="14sp"
        android:letterSpacing="0.06"
        android:fontFamily="@font/cinzel"
        android:textColor="@color/cream"
        android:background="@drawable/bg_ink_card"
        android:foreground="?attr/selectableItemBackground" />

    <TextView
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:padding="10dp"
        android:text="Remove this Appointment"
        android:textSize="13sp"
        android:textStyle="italic"
        android:fontFamily="@font/dm_sans"
        android:textColor="@color/butler_red"
        android:background="?attr/selectableItemBackground"
        android:visibility="gone" />
</LinearLayout>
