<?xml version="1.0" encoding="utf-8"?>
<!-- The Parlour — main screen (design: ParlourScreen.tsx) -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header: apple + THE PARLOUR + greeting | bowler hat button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:src="@drawable/ic_tuxedo"
                        app:tint="@color/ink"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="THE PARLOUR"
                        android:textSize="11sp"
                        android:letterSpacing="0.16"
                        android:fontFamily="@font/cinzel"
                        android:textColor="@color/warm_grey" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxWidth="260dp"
                    android:text="Good morning, Sir."
                    android:textSize="18sp"
                    android:textStyle="italic"
                    android:fontFamily="@font/playfair_display"
                    android:textColor="@color/ink"
                    android:lineSpacingMultiplier="1.25" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/btnPrefs"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_ink_circle"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_bowler_hat"
                    app:tint="@color/cream"
                    android:contentDescription="Butler preferences" />
            </FrameLayout>
        </LinearLayout>

        <!-- Live clock strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:background="@drawable/bg_ink_card">

            <TextView
                android:id="@+id/tvClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="07:07"
                android:textSize="46sp"
                android:fontFamily="@font/cinzel"
                android:letterSpacing="0.01"
                android:textColor="@color/wake_text" />

            <TextView
                android:id="@+id/tvClockSeconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"
                android:layout_gravity="bottom"
                android:text=":00"
                android:textSize="16sp"
                android:fontFamily="@font/cinzel"
                android:textColor="@color/powder_blue" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvWeekday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WED"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/cinzel"
                    android:textColor="@color/warm_grey" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9 Jul"
                    android:textSize="13sp"
                    android:fontFamily="@font/cinzel"
                    android:textColor="@color/powder_blue" />

                <TextView
                    android:id="@+id/tvWeather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="16° · Clear"
                    android:textSize="11sp"
                    android:letterSpacing="0.04"
                    android:fontFamily="@font/cinzel"
                    android:textColor="@color/warm_grey"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- N SCHEDULED | Preview Wake-Up → -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvScheduledCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 SCHEDULED"
                android:textSize="11sp"
                android:letterSpacing="0.14"
                android:fontFamily="@font/cinzel"
                android:textColor="@color/warm_grey" />

            <TextView
                android:id="@+id/btnPreviewWake"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preview Wake-Up →"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:fontFamily="@font/cinzel"
                android:textColor="@color/powder_blue"
                android:padding="4dp"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <!-- Alarm list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAlarms"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="110dp"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvEmptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No appointments, Sir."
            android:textSize="16sp"
            android:textStyle="italic"
            android:fontFamily="@font/playfair_display"
            android:textColor="@color/faded_grey" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Remarkably free calendar."
            android:textSize="13sp"
            android:fontFamily="@font/dm_sans"
            android:textColor="#C0BAB0" />
    </LinearLayout>

    <!-- FAB — serving bell -->
    <FrameLayout
        android:id="@+id/fabAdd"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_ink_circle"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:elevation="8dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_bell"
            app:tint="@color/cream"
            android:contentDescription="Add alarm" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
