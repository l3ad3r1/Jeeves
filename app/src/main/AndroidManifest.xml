<?xml version="1.0" encoding="utf-8"?>
<!--
    Hermes Agent — AndroidManifest
    Phase 1 (Foundation) of the technical plan.

    Permissions:
      - INTERNET / ACCESS_NETWORK_STATE : cloud LLM fallback (Phase 1 stub wired)
      - RECORD_AUDIO                    : voice input placeholder (Phase 3)
      - POST_NOTIFICATIONS              : notification agent placeholder (Phase 3)
    Hardware features (Knox) are declared as not-required so the app installs on
    any Android 10+ device for development & testing.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Always-on agent: foreground service (24/7) + restart on boot. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- In-app OTA updater: install the downloaded release APK without a browser. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- SMS gateway (sent via the notify tool / SmsManager). -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Setup journey: capabilities the agent can use (requested at runtime). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Run commands in the separately-installed Termux app (RUN_COMMAND). -->
    <uses-permission android:name="com.termux.permission.RUN_COMMAND" />

    <!-- Android 11+ package visibility: allow resolving/launching Termux. -->
    <queries>
        <package android:name="com.termux" />
    </queries>

    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:name=".HermesApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HermesAgent"
        android:extractNativeLibs="true"
        tools:targetApi="34">

        <activity
            android:name=".ui.share.ShareTargetActivity"
            android:exported="true"
            android:theme="@style/Theme.HermesAgent.Transparent">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.HermesAgent">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Always-on agent service: keeps Hermes working the Kanban board across Doze. -->
        <service
            android:name=".service.AgentForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Local OpenAI-compatible API server (opt-in, Settings-controlled). -->
        <service
            android:name=".service.ApiServerService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Widgets -->
        <receiver android:name=".ui.widget.BriefingWidgetProvider" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_briefing" />
        </receiver>

        <receiver android:name=".ui.widget.QuickJotWidgetProvider" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_quick_jot" />
        </receiver>

        <!-- Receivers -->
        <receiver android:name=".receiver.NotificationReplyReceiver" android:exported="false">
            <intent-filter>
                <action android:name="com.hermes.agent.action.REPLY" />
            </intent-filter>
        </receiver>

        <!-- OTA download foreground service -->
        <service
            android:name=".data.update.OtaDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Quick Settings Tile -->
        <service
            android:name=".ui.tile.JeevesQuickTileService"
            android:exported="true"
            android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".service.JeevesVoiceInteractionService"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true">
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/voice_interaction" />
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

        <service
            android:name=".service.JeevesVoiceInteractionSessionService"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true" />

        <!-- Restarts the agent service after device reboot. -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Serves the downloaded update APK to the system installer (in-app OTA). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- WorkManager initialization deferred to HermesApp via HiltWorkerFactory -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
            <!-- Starts MemoryPressureMonitor before the first screen; HermesApp.onCreate is the fallback. -->
            <meta-data
                android:name="com.hermes.agent.data.performance.MemoryMonitorInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>
</manifest>
